  "tokenColors": [
    // ── Base ────────────────────────────────────────────────
    {
      "name": "Default text",
      "scope": "source, text",
      "settings": { "foreground": "#FFFFFF" }
    },

    // ── Comments ────────────────────────────────────────────
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#4a1a1a", "fontStyle": "italic" }
    },
    {
      "name": "JSDoc tags",
      "scope": "comment.block.documentation storage.type.class.jsdoc",
      "settings": { "foreground": "#661a1a", "fontStyle": "italic" }
    },
    {
      "name": "JSDoc param names",
      "scope": "comment.block.documentation entity.name.type.instance.jsdoc",
      "settings": { "foreground": "#5a1a1a" }
    },

    // ── Keywords ────────────────────────────────────────────
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.delete",
        "keyword.operator.typeof",
        "keyword.operator.void",
        "keyword.operator.in",
        "keyword.operator.instanceof",
        "keyword.operator.of",
        "storage.type",
        "storage.modifier"
      ],
      "settings": { "foreground": "#FF2200", "fontStyle": "" }
    },
    {
      "name": "Import/Export keywords",
      "scope": [
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from",
        "keyword.control.as"
      ],
      "settings": { "foreground": "#FF2200" }
    },
    {
      "name": "This / Super",
      "scope": ["variable.language.this", "variable.language.super"],
      "settings": { "foreground": "#FF2200", "fontStyle": "italic" }
    },
    {
      "name": "Null / Undefined / Boolean literals",
      "scope": [
        "constant.language.null",
        "constant.language.undefined",
        "constant.language.boolean",
        "constant.language.nan",
        "constant.language.infinity"
      ],
      "settings": { "foreground": "#FF2200" }
    },

    // ── Operators ───────────────────────────────────────────
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment",
        "keyword.operator.arithmetic",
        "keyword.operator.comparison",
        "keyword.operator.logical",
        "keyword.operator.bitwise",
        "keyword.operator.ternary",
        "keyword.operator.spread",
        "keyword.operator.optional"
      ],
      "settings": { "foreground": "#FF3300" }
    },
    {
      "name": "Arrow function operator",
      "scope": "storage.type.function.arrow",
      "settings": { "foreground": "#FF3300" }
    },

    // ── Types ───────────────────────────────────────────────
    {
      "name": "Type names & classes",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.interface",
        "entity.name.enum",
        "entity.name.type.alias",
        "support.class",
        "support.type"
      ],
      "settings": { "foreground": "#FF5500" }
    },
    {
      "name": "Built-in types (TS primitives)",
      "scope": [
        "support.type.primitive",
        "support.type.builtin",
        "keyword.type"
      ],
      "settings": { "foreground": "#FF2200" }
    },
    {
      "name": "Type parameters / generics",
      "scope": [
        "entity.name.type.type-parameter",
        "variable.type.var"
      ],
      "settings": { "foreground": "#FF6633", "fontStyle": "italic" }
    },
    {
      "name": "Inherited class",
      "scope": "entity.other.inherited-class",
      "settings": { "foreground": "#FF5500", "fontStyle": "italic" }
    },

    // ── Decorators ──────────────────────────────────────────
    {
      "name": "Decorators",
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "entity.name.function.tagged-template"
      ],
      "settings": { "foreground": "#FF4400" }
    },

    // ── Functions ───────────────────────────────────────────
    {
      "name": "Function name declarations",
      "scope": [
        "entity.name.function",
        "meta.definition.method entity.name.function"
      ],
      "settings": { "foreground": "#FF8800" }
    },
    {
      "name": "Function calls",
      "scope": [
        "meta.function-call entity.name.function",
        "meta.method-call entity.name.function",
        "support.function"
      ],
      "settings": { "foreground": "#FF8800" }
    },
    {
      "name": "Built-in functions / console",
      "scope": [
        "support.function.console",
        "entity.name.function.member"
      ],
      "settings": { "foreground": "#FF9900" }
    },

    // ── Variables ───────────────────────────────────────────
    {
      "name": "Variable declarations",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite",
        "variable.other.object",
        "meta.definition.variable variable.other.readwrite"
      ],
      "settings": { "foreground": "#FFFFFF" }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter",
        "meta.parameters variable.other.readwrite"
      ],
      "settings": { "foreground": "#E8E8E8", "fontStyle": "italic" }
    },
    {
      "name": "Destructuring / rest",
      "scope": [
        "variable.other.object.destructured",
        "variable.other.rest"
      ],
      "settings": { "foreground": "#FFFFFF" }
    },

    // ── Properties ──────────────────────────────────────────
    {
      "name": "Object properties & member access",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "support.variable.property",
        "meta.object-literal.key",
        "entity.other.attribute-name"
      ],
      "settings": { "foreground": "#FF6633" }
    },

    // ── Strings ─────────────────────────────────────────────
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": { "foreground": "#FFA040" }
    },
    {
      "name": "String punctuation",
      "scope": [
        "punctuation.definition.string",
        "punctuation.definition.template-expression"
      ],
      "settings": { "foreground": "#FF8833" }
    },
    {
      "name": "Template expression contents",
      "scope": "meta.template.expression",
      "settings": { "foreground": "#FFFFFF" }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp",
        "constant.regexp"
      ],
      "settings": { "foreground": "#FF7722" }
    },
    {
      "name": "Regex groups & quantifiers",
      "scope": [
        "keyword.operator.quantifier.regexp",
        "keyword.operator.or.regexp",
        "punctuation.definition.group.regexp"
      ],
      "settings": { "foreground": "#FF5500" }
    },

    // ── Numbers ─────────────────────────────────────────────
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric",
        "constant.numeric.integer",
        "constant.numeric.float",
        "constant.numeric.hex",
        "constant.numeric.octal",
        "constant.numeric.binary"
      ],
      "settings": { "foreground": "#FFAA00" }
    },

    // ── Constants ───────────────────────────────────────────
    {
      "name": "Constants",
      "scope": [
        "constant.other",
        "variable.other.constant"
      ],
      "settings": { "foreground": "#FF8800" }
    },

    // ── Punctuation ─────────────────────────────────────────
    {
      "name": "Punctuation & brackets",
      "scope": [
        "punctuation",
        "meta.brace",
        "punctuation.definition.block",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": { "foreground": "#882200" }
    },

    // ── TypeScript specific ─────────────────────────────────
    {
      "name": "TS — Access modifiers",
      "scope": [
        "storage.modifier.ts",
        "storage.modifier.tsx"
      ],
      "settings": { "foreground": "#FF2200", "fontStyle": "italic" }
    },
    {
      "name": "TS — Interface / type keyword",
      "scope": [
        "storage.type.interface.ts",
        "storage.type.type.ts",
        "storage.type.enum.ts",
        "storage.type.class.ts",
        "storage.type.namespace.ts"
      ],
      "settings": { "foreground": "#FF2200" }
    },
    {
      "name": "TS — Type assertion / as / satisfies",
      "scope": [
        "keyword.control.as.ts",
        "keyword.operator.expression.satisfies.ts",
        "keyword.operator.expression.keyof.ts",
        "keyword.operator.expression.typeof.ts",
        "keyword.operator.expression.infer.ts"
      ],
      "settings": { "foreground": "#FF3300" }
    },
    {
      "name": "TS — Mapped types / conditional",
      "scope": [
        "keyword.operator.expression.extends.ts",
        "keyword.operator.expression.in.ts"
      ],
      "settings": { "foreground": "#FF3300" }
    },
    {
      "name": "TS — Namespace/module name",
      "scope": [
        "entity.name.namespace",
        "entity.name.module"
      ],
      "settings": { "foreground": "#FF5500" }
    },

    // ── JSX / TSX ───────────────────────────────────────────
    {
      "name": "JSX tag names",
      "scope": [
        "entity.name.tag",
        "support.class.component"
      ],
      "settings": { "foreground": "#FF5500" }
    },
    {
      "name": "JSX attribute names",
      "scope": "entity.other.attribute-name.jsx",
      "settings": { "foreground": "#FF6633" }
    },
    {
      "name": "JSX punctuation",
      "scope": [
        "punctuation.definition.tag",
        "punctuation.section.embedded"
      ],
      "settings": { "foreground": "#882200" }
    },

    // ── Imports / Modules ───────────────────────────────────
    {
      "name": "Import module path",
      "scope": [
        "string.quoted.double.import",
        "string.quoted.single.import",
        "meta.import string"
      ],
      "settings": { "foreground": "#FFA040" }
    },
    {
      "name": "Import specifiers (names)",
      "scope": "meta.import variable.other.readwrite",
      "settings": { "foreground": "#FFFFFF" }
    },

    // ── Markdown (bonus) ─────────────────────────────────────
    {
      "name": "Markdown headings",
      "scope": "markup.heading",
      "settings": { "foreground": "#FF5500", "fontStyle": "bold" }
    },
    {
      "name": "Markdown bold",
      "scope": "markup.bold",
      "settings": { "foreground": "#FF8800", "fontStyle": "bold" }
    },
    {
      "name": "Markdown italic",
      "scope": "markup.italic",
      "settings": { "foreground": "#FF6633", "fontStyle": "italic" }
    },
    {
      "name": "Markdown code",
      "scope": "markup.inline.raw",
      "settings": { "foreground": "#FFAA00" }
    },
    {
      "name": "Markdown link",
      "scope": "markup.underline.link",
      "settings": { "foreground": "#FF8800" }
    },
    {
